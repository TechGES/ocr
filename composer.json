{
    "name": "ges/ocr",
    "description": "Core document processing services for OCR, classification, extraction, and normalization.",
    "keywords": [
        "laravel",
        "ocr",
        "document-processing",
        "identity-documents",
        "ollama"
    ],
    "type": "library",
    "license": "MIT",
    "version": "0.1.0",
    "require": {
        "php": "^8.4",
        "illuminate/http": "^12.0",
        "illuminate/support": "^12.0",
        "nesbot/carbon": "^3.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Ges\\Ocr\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ges\\Ocr\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ges\\Ocr\\Providers\\DocumentProcessingServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
